# ═══════════════════════════════════════════════════════════════════
# REE WhatsApp Bot — Environment Variables
# GRIH SANSAR DEPARTMENTAL STORE
# ═══════════════════════════════════════════════════════════════════

# ─── WhatsApp Business API ────────────────────────────────────────
# Get from: https://developers.facebook.com → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
WHATSAPP_VERIFY_TOKEN=ree_grihsansar_2026
WHATSAPP_BUSINESS_ID=your_business_id

# ─── Cloudflare Workers AI (replaces Gemini / Grok) ─────────────────────
# Get from: Cloudflare Dashboard → Workers AI → REST API token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_AI_TOKEN=your_cloudflare_ai_api_token

# (Optional) If you are still using Grok, you can keep the old key here
# GROK_API_KEY=your_grok_api_key
# GROK_MODEL=grok-1.0

# ─── Server ───────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────
DB_PATH=./database/ree_store.db

# ─── Store Info ───────────────────────────────────────────────────
STORE_PHONE=+91XXXXXXXXXX
STORE_ADDRESS=Shop No. XX, Main Market, Your City
